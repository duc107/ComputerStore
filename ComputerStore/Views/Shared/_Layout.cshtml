<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ComputerStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ComputerStore.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- PHẦN ĐẦU: THANH MENU -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">💻 ComputerStore</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold text-success" asp-area="" asp-controller="Cart" asp-action="Index">🛒 Giỏ Hàng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Cart" asp-action="History">
                                📦 Lịch sử đơn hàng
                            </a>
                        </li>
                        @* <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Warranty" asp-action="Lookup">🔧 Tra cứu bảo hành</a>
                        </li> *@
                        
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- PHẦN THÂN: NƠI HIỂN THỊ NỘI DUNG CÁC TRANG -->
    <div class="container">
        <main role="main" class="pb-3">
            <!-- ĐÂY CHÍNH LÀ DÒNG BỊ THIẾU GÂY RA LỖI -->
            @RenderBody()
        </main>
    </div>

    <!-- PHẦN CHÂN TRANG (FOOTER) -->
    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            &copy; 2024 - Hệ thống bán lẻ ComputerStore
        </div>
    </footer>

    <!-- CÁC THƯ VIỆN JAVASCRIPT -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>