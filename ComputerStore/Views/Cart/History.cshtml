@model List<ComputerStore.Models.Order>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary fw-bold">📦 Đơn hàng của tôi</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">Bạn chưa có đơn hàng nào!</div>
    }
    else
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Mã Đơn</th>
                        <th>Ngày Đặt</th>
                        <th>Tổng Tiền</th>
                        <th>Trạng Thái</th>
                        <th class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>#@item.OrderId</strong></td>
                            <td>@item.OrderDate?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0") VNĐ</td>
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                }
                                else
                                {

                                    <span class="badge bg-success">@item.Status</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-controller="Cart" asp-action="OrderDetails" asp-route-id="@item.OrderId" class="btn btn-sm btn-outline-primary">
                                    Xem Chi Tiết
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>