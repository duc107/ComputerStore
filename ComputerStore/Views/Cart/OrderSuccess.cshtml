@{
    ViewData["Title"] = "Đặt hàng thành công";
    var orderId = ViewBag.OrderId;
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <span style="font-size:4rem;">✅</span>
                    </div>
                    <h2 class="fw-bold mb-3">🎉 Đặt hàng thành công!</h2>
                    <p class="lead text-muted mb-4">
                        Mã đơn hàng của bạn là:
                        <span class="badge bg-primary fs-5">#@orderId</span>
                    </p>
                    <div class="alert alert-info">
                        Dùng Serial Number trên banner Trang chủ để tra cứu bảo hành.
                    </div>
                    <a href="/" class="btn btn-outline-primary btn-lg">🏠 Về Trang chủ</a>
                    <a asp-action="PrintInvoice" asp-route-id="@orderId" target="_blank" class="btn btn-success btn-lg ms-2">
                        🖨 In Hóa Đơn
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>